{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "Node",
        "outDir": "./dist",
        "rootDir": "./",
        "noEmit": false
    },
    "include": [
        "workers/**/*",
        "src/lib/queue/**/*",
        "src/lib/db/**/*",
        "src/lib/constants.ts",
        "src/lib/email.ts"
    ],
    "exclude": [
        "node_modules",
        "src/app"
    ]
}