# ══════════════════════════════════════════════════════════════
# eMarketer Multi-Region Configuration
#
# Defines available deploy regions and their server details.
# Used by deploy queue to route instances to the nearest server.
# ══════════════════════════════════════════════════════════════

# Available regions
# Format: REGION_KEY=IP:SSH_PORT:CAPACITY
DEPLOY_REGIONS='{
    "vn-hcm-1": {
        "name": "Hồ Chí Minh #1",
        "host": "76.13.190.139",
        "sshPort": 22,
        "sshUser": "root",
        "maxInstances": 50,
        "currentInstances": 0,
        "region": "asia-southeast1",
        "country": "VN",
        "priority": 1,
        "features": ["postgres", "docker", "nginx", "certbot"]
    },
    "vn-hn-1": {
        "name": "Hà Nội #1",
        "host": "",
        "sshPort": 22,
        "sshUser": "root",
        "maxInstances": 50,
        "currentInstances": 0,
        "region": "asia-southeast1",
        "country": "VN",
        "priority": 2,
        "features": ["postgres", "docker", "nginx", "certbot"],
        "disabled": true
    }
}'

# Default region (used when customer doesn't specify)
DEFAULT_DEPLOY_REGION=vn-hcm-1

# Region selection strategy
# "nearest"    → select by customer country
# "least_loaded" → select by fewest instances
# "priority"   → select by priority field
REGION_STRATEGY=priority

# SSH key for deployer to connect to remote servers
# DEPLOY_SSH_KEY_PATH=/root/.ssh/deploy_ed25519

# ── Deploy Worker ──────────────────────────────────────────────
# Number of concurrent deploy workers
DEPLOY_WORKER_COUNT=2

# Poll interval for deploy queue (seconds)
DEPLOY_POLL_INTERVAL=10

# ── Backup ─────────────────────────────────────────────────────
# S3-compatible backup storage (optional)
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_BUCKET=emk-backups
# BACKUP_S3_KEY=
# BACKUP_S3_SECRET=

# Local backup retention (days)
BACKUP_RETENTION_DAYS=30
