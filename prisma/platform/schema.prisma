generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/platform"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth / RBAC ───────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String
  name         String
  phone        String   @unique
  status             String    @default("ACTIVE") // ACTIVE | DISABLED
  isAdmin            Boolean   @default(false)     // platform super-admin
  emkRole            String?   // ADMIN | OPS | SALES | CS (null = not eMarketer staff)
  loginToken         String?   @unique
  loginTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  ownedOrgs      Org[]
  memberships    Membership[]
  eventLogs      EventLog[]
  errorLogs      ErrorLog[]
  importJobs     ImportJob[]
  setting        UserSetting?
  emkLeadsOwned  EmkLead[]     @relation("LeadOwner")
  emkTasksOwned  EmkTask[]     @relation("TaskOwner")
  emkNotes       EmkNote[]     @relation("NoteAuthor")
  wallet         Wallet?
  supportTickets SupportTicket[]
  ticketMessages TicketMessage[]
  emailTemplates EmkEmailTemplate[] @relation("TemplateAuthor")
  emkCampaigns   EmkDripCampaign[]  @relation("CampaignAuthor")
  achievements   Achievement[]
  kbArticles     KbArticle[]        @relation("KbAuthor")
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("AUTO") // LIGHT, DARK, AUTO
  // Notification preferences
  notifBilling  Boolean @default(true)
  notifTask     Boolean @default(true)
  notifSystem   Boolean @default(true)
  notifUpdate   Boolean @default(true)
  notifPromo    Boolean @default(true)
  digestMode    String  @default("INSTANT") // INSTANT, DAILY, WEEKLY
  quietStart    String? // HH:mm format, e.g. "22:00"
  quietEnd      String? // HH:mm format, e.g. "07:00"
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Org {
  id          String   @id @default(cuid())
  name        String
  ownerUserId String
  createdAt   DateTime @default(now())

  owner      User        @relation(fields: [ownerUserId], references: [id])
  workspaces Workspace[]
}

model Workspace {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  slug      String   @unique
  product   String   @default("SPA") // product type
  status    String   @default("ACTIVE") // ACTIVE | SUSPENDED
  createdAt DateTime @default(now())

  org              Org               @relation(fields: [orgId], references: [id])
  memberships      Membership[]
  eventLogs        EventLog[]
  errorLogs        ErrorLog[]
  importJobs       ImportJob[]
  productInstances ProductInstance[]
  provisioningJobs ProvisioningJob[]
  entitlements     Entitlement[]
  subscriptions    Subscription[]
  upgradeOrders    UpgradeOrder[]
  paymentTxns      PaymentTxn[]
  paymentProofs    PaymentProof[]
  reminderRules    ReminderRule[]
  reminderLogs     ReminderLog[]
  aiProviderKeys   AiProviderKey[]
  emkAccount       EmkAccount?

  @@index([orgId])
}

model Membership {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("STAFF") // OWNER | ADMIN | STAFF
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model EventLog {
  id          String   @id @default(cuid())
  workspaceId String?
  actorUserId String?
  type        String
  payloadJson Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  actor     User?      @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId, type, createdAt])
}

model ErrorLog {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  path        String?
  message     String
  stack       String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
}

model ImportJob {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  status      String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  failedRows  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace   @relation(fields: [workspaceId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  importRows ImportRow[]

  @@index([workspaceId, status])
}

model ImportRow {
  id          String   @id @default(cuid())
  jobId       String
  rawJson     Json
  status      String   @default("PENDING") // RUNNING, SUCCESS, FAILED
  errorMsg    String?

  job ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ─── Provisioning ──────────────────────────────────────────

model ProductInstance {
  id          String   @id @default(cuid())
  workspaceId String
  productKey  String   @default("SPA_CRM")
  baseUrl     String
  status      String   @default("PENDING") // PENDING | ACTIVE | FAILED
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model ProvisioningJob {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // SEED_SPA
  status      String   @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([status])
}

// ─── Marketplace / Entitlements ────────────────────────────

model Module {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  description  String?
  priceMonthly Int      @default(0) // in VND
  icon         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Entitlement {
  id              String    @id @default(cuid())
  workspaceId     String
  userId          String?
  productId       String?
  moduleKey       String
  scope           String    @default("ORG")   // ORG | USER | TENANT
  status          String    @default("ACTIVE") // ACTIVE | INACTIVE | REVOKED
  precedenceLevel Int       @default(0)  // higher wins: manual > addon > plan
  featureFlags    Json?     // {"automation": true, "aiWriter": true}
  limits          Json?     // {"maxUsers": 10, "maxStorage": 5000}
  activeFrom      DateTime  @default(now())
  activeTo        DateTime?
  revokedAt       DateTime?
  revokeReason    String?
  meta            Json?     // {tenantId, orderId, productType}
  createdAt       DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, moduleKey])
  @@index([workspaceId, createdAt])
  @@index([userId, productId])
  @@index([status, activeTo])
}

model Plan {
  id            String    @id @default(cuid())
  key           String    @unique
  productId     String?
  name          String
  price         Int       @default(0)        // VND
  cycle         String    @default("MONTHLY") // MONTHLY | YEARLY | ONE_TIME
  trialDays     Int       @default(0)        // trial period days
  features      Json?     // [{text, included}]
  limits        Json?     // {maxUsers, maxStorage, ...}
  isActive      Boolean   @default(true)
  version       Int       @default(1)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  limitsJson    Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())

  @@index([productId, isActive])
  @@index([productId, effectiveFrom])
}

model Subscription {
  id                 String    @id @default(cuid())
  workspaceId        String
  userId             String?
  productId          String?
  planId             String?
  planKey            String
  status             String    @default("TRIAL") // TRIAL | ACTIVE | PAST_DUE | SUSPENDED | CANCELED | EXPIRED
  trialEndsAt        DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  graceUntil         DateTime?
  canceledAt         DateTime?
  cancelReason       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  reminderLogs ReminderLog[]

  @@index([workspaceId])
  @@index([userId, productId])
  @@index([status, currentPeriodEnd])
  @@index([trialEndsAt])
}

// ─── Billing ───────────────────────────────────────────────

model UpgradeOrder {
  id          String    @id @default(cuid())
  workspaceId String
  orderCode   String    @unique
  itemsJson   Json
  amount      Int       // VND
  status      String    @default("PENDING") // PENDING | PAID | EXPIRED | NEED_REVIEW
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([orderCode])
  @@index([status])
}

model PaymentTxn {
  id          String   @id @default(cuid())
  workspaceId String
  provider    String
  txnRef      String   @unique
  amount      Int
  description String?
  paidAt      DateTime
  rawJson     Json?    // minimal, no sensitive data
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([txnRef])
}

// ─── Dunning / Reminders ──────────────────────────────────

model ReminderRule {
  id           String   @id @default(cuid())
  workspaceId  String
  type         String   @default("RENEWAL")
  offsetsJson  Json     // [-7, -3, -1, 1, 3]
  channelsJson Json     // ["EMAIL", "SMS"]
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model ReminderLog {
  id             String   @id @default(cuid())
  workspaceId    String
  subscriptionId String
  offsetDay      Int
  channel        String   // EMAIL | SMS | ZALO
  status         String   @default("PENDING") // PENDING | SENT | FAILED
  sentAt         DateTime?
  metaJson       Json?
  createdAt      DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([subscriptionId])
}

// ─── AI Vault ─────────────────────────────────────────────

model AiProviderKey {
  id             String   @id @default(cuid())
  workspaceId    String
  provider       String   // OPENAI | GOOGLE | ANTHROPIC
  keyCiphertext  String   // AES-256-GCM encrypted
  keyIv          String   // Initialization vector
  keyAuthTag     String   // Auth tag
  keyLast4       String
  status         String   @default("ACTIVE") // ACTIVE | REVOKED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

// ─── Help Center ──────────────────────────────────────────

model HelpDoc {
  id         String   @id @default(cuid())
  productKey String   @default("SPA_CRM")
  moduleKey  String?
  title      String
  slug       String   @unique
  contentMd  String
  sortOrder  Int      @default(0)
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([productKey, moduleKey])
}

// ─── Hub Marketplace Products ─────────────────────────────

model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String   @default("📁")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Product {
  id             String   @id @default(cuid())
  key            String   @unique
  slug           String   @unique
  name           String
  type           String   @default("CRM")              // CRM | APP | DIGITAL
  billingModel   String   @default("SUBSCRIPTION")     // SUBSCRIPTION | PAYG | ONE_TIME | MIXED
  deliveryMethod String   @default("PROVISION_TENANT") // PROVISION_TENANT | ENABLE_APP | DOWNLOAD_GRANT
  status         String   @default("DRAFT")            // DRAFT | PUBLISHED | ARCHIVED
  tagline        String?  // 1 dòng mô tả ngắn
  outcomeText    String?  // mô tả kết quả
  description    String?  @db.Text // mô tả chi tiết
  usageGuide     String?  @db.Text // hướng dẫn sử dụng
  thumbnail      String?  // URL ảnh đại diện
  industry       String[] // category slugs
  icon           String?
  priceOriginal  Int      @default(0) // giá gốc (VND)
  priceRental    Int      @default(0) // giá thuê (VND/tháng)
  priceSale      Int      @default(0) // giá bán (VND)
  priceMonthly   Int      @default(0) // backward compat
  features       Json?    // [{text, included}]
  faq            Json?    // [{q, a}]
  metadata       Json?    // extra config
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meteredItems   MeteredItem[]
  digitalAssets  DigitalAsset[]
  plans          Plan_Product[]

  @@index([type, status])
  @@index([billingModel])
}

// ─── Commerce Layer ──────────────────────────────────────

model MeteredItem {
  id            String    @id @default(cuid())
  productId     String
  key           String   // IMAGE_GEN, AI_WRITE, SMS
  unitName      String   @default("lượt")  // lượt, tin, ảnh
  unitPrice     Int      @default(0)       // VND per unit
  version       Int      @default(1)
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([productId, isActive])
  @@index([productId, effectiveFrom])
}

// Plan linked to Product (junction for N:M if needed)
model Plan_Product {
  id        String @id @default(cuid())
  planId    String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([planId, productId])
}

model CommerceOrder {
  id              String    @id @default(cuid())
  userId          String
  orgId           String?
  source          String    @default("HUB") // HUB | CRM_REDIRECT
  status          String    @default("PENDING") // PENDING | PAID | FAILED | REFUNDED | PARTIAL_REFUND
  totalAmount     Int       @default(0)
  refundedAmount  Int       @default(0)
  discountAmount  Int       @default(0)
  couponId        String?
  currency        String    @default("VND")
  idempotencyKey  String?   @unique
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items      OrderItem[]
  grants     DownloadGrant[]
  refunds    RefundRecord[]

  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([status])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  productId     String
  planId        String?
  quantity      Int    @default(1)
  unitPrice     Int    @default(0)
  lineTotal     Int    @default(0)
  priceSnapshot Json?  // {unitPrice, cycle, version} at time of purchase
  meta          Json?  // {cycle, duration, ...}

  order CommerceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model UsageEvent {
  id              String   @id @default(cuid())
  userId          String
  orgId           String?
  productId       String
  meteredItemKey  String
  quantity        Int      @default(1)
  unitPrice       Int      @default(0)
  total           Int      @default(0)
  status          String   @default("PENDING") // PENDING | SUCCEEDED | FAILED | REVERSED
  requestId       String   @unique // idempotency key
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([userId, productId, createdAt])
  @@index([requestId])
  @@index([status])
}

// ─── Digital Assets & Delivery ───────────────────────────

model DigitalAsset {
  id         String   @id @default(cuid())
  productId  String
  fileKey    String   // relative path or S3 key
  filename   String   // display name
  size       Int      @default(0)  // bytes
  checksum   String?  // sha256
  version    String   @default("1.0")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  grants  DownloadGrant[]

  @@index([productId, isActive])
}

model DownloadGrant {
  id            String    @id @default(cuid())
  userId        String
  productId     String
  orderId       String?
  assetId       String
  maxDownloads  Int       @default(5)
  downloadCount Int       @default(0)
  licenseKey    String?   @unique  // user-bound license
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokeReason  String?
  createdAt     DateTime  @default(now())

  asset DigitalAsset  @relation(fields: [assetId], references: [id])
  order CommerceOrder? @relation(fields: [orderId], references: [id])
  logs  DownloadLog[]

  @@index([userId, productId])
  @@index([orderId])
  @@index([licenseKey])
}

model DownloadLog {
  id           String   @id @default(cuid())
  grantId      String
  downloadedAt DateTime @default(now())
  ip           String?
  userAgent    String?

  grant DownloadGrant @relation(fields: [grantId], references: [id])

  @@index([grantId])
}

// ─── Refund & Reverse ────────────────────────────────────

model RefundRecord {
  id            String   @id @default(cuid())
  orderId       String
  userId        String
  amount        Int      // refund amount in VND
  type          String   @default("FULL") // FULL | PARTIAL | CHARGEBACK
  reason        String
  status        String   @default("PENDING") // PENDING | APPROVED | PROCESSED | REJECTED
  processedBy   String?  // admin userId who processed
  processedAt   DateTime?
  idempotencyKey String  @unique
  metadata      Json?
  createdAt     DateTime @default(now())

  order CommerceOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([userId, createdAt])
  @@index([status])
}

// ─── Coupon / Promo ──────────────────────────────────────

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  type           String    @default("PERCENT") // PERCENT | FIXED
  value          Int       // percent (1-100) or fixed VND amount
  minOrderAmount Int       @default(0)
  maxDiscount    Int?      // cap for PERCENT type
  maxUses        Int       @default(0) // 0 = unlimited
  usedCount      Int       @default(0)
  productIds     String[]  // restrict to specific products (empty = all)
  planIds        String[]  // restrict to specific plans
  startsAt       DateTime  @default(now())
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdBy      String?
  createdAt      DateTime  @default(now())

  redemptions CouponRedemption[]

  @@index([code, isActive])
  @@index([expiresAt])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  discount  Int      @default(0)  // actual discount applied
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@unique([couponId, userId, orderId])
  @@index([userId])
}

// ─── PAYG Quota & Rate Limiting ──────────────────────────

model UsageQuota {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  itemKey      String
  quotaLimit   Int      @default(0)   // max units per period (0=unlimited)
  quotaUsed    Int      @default(0)
  periodType   String   @default("MONTHLY") // DAILY | MONTHLY
  periodStart  DateTime @default(now())
  periodEnd    DateTime
  rateLimit    Int      @default(60)  // max requests per minute
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())

  @@unique([userId, productId, itemKey, periodStart])
  @@index([userId, productId, periodEnd])
}

// ─── Receipt / Invoice ───────────────────────────────────

model Receipt {
  id          String   @id @default(cuid())
  userId      String
  orderId     String?
  topupId     String?
  type        String   @default("PURCHASE") // PURCHASE | TOPUP | REFUND | SUBSCRIPTION
  amount      Int      @default(0)
  description String
  receiptNo   String   @unique  // auto-generated EMK-YYYY-MMDD-XXXX
  metadata    Json?    // extra display data
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

// ─── Notification Queue ──────────────────────────────────

model NotificationQueue {
  id          String    @id @default(cuid())
  userId      String
  type        String    // LOW_BALANCE | CHARGE_FAIL | SUB_EXPIRING | ENTITLEMENT_GRANTED | DOWNLOAD_READY | REFUND_PROCESSED
  channel     String    @default("IN_APP") // IN_APP | EMAIL | SMS | PUSH
  title       String
  body        String
  referenceType String? // ORDER | USAGE_EVENT | SUBSCRIPTION | DOWNLOAD_GRANT
  referenceId   String?
  status      String    @default("PENDING") // PENDING | SENT | READ | FAILED
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, status, createdAt])
  @@index([type, status])
}

model PaymentProof {
  id          String   @id @default(cuid())
  workspaceId String
  orderId     String?
  imageUrl    String
  note        String?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([status])
}

// ─── eMarketer CRM (Internal Ops) ─────────────────────────

model EmkLead {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  email       String?
  industry    String?   // SPA, SALES, PERSONAL
  size        String?   // SOLO, SMALL, MEDIUM
  need        String?
  source      String?   // LP_SPA, LP_SALES, LP_SOLO, DIRECT, AFF
  utmSource   String?
  utmCampaign String?
  utmMedium   String?
  status      String    @default("NEW") // NEW|CONTACTED|ONBOARDING|ACTIVE|RENEWAL|AT_RISK|CHURNED|LOST
  tags        String?   // Comma-separated tags, e.g. "VIP,HOT,NURTURE"
  score       Int       @default(0)  // Lead score 0-100
  ownerId     String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner    User?       @relation("LeadOwner", fields: [ownerId], references: [id])
  tasks    EmkTask[]   @relation("LeadTasks")
  notes    EmkNote[]   @relation("LeadNotes")
  referral Referral?

  @@index([status, createdAt])
  @@index([ownerId, status])
  @@index([phone])
}

model EmkAccount {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  leadId         String?
  plan           String    @default("TRIAL") // TRIAL | STARTER | PRO
  trialStartAt   DateTime  @default(now())
  trialEndAt     DateTime?
  lastActivityAt DateTime?
  status         String    @default("TRIAL") // TRIAL|ACTIVE|PAST_DUE|CHURNED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  tasks     EmkTask[] @relation("AccountTasks")
  notes     EmkNote[] @relation("AccountNotes")

  @@index([status, trialEndAt])
}

model EmkTask {
  id               String    @id @default(cuid())
  title            String
  type             String    @default("GENERAL") // CALL|DEMO|FOLLOW_UP|RENEWAL|GENERAL
  ownerId          String?
  relatedLeadId    String?
  relatedAccountId String?
  dueDate          DateTime?
  status           String    @default("OPEN") // OPEN | DONE | CANCELLED
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner   User?       @relation("TaskOwner", fields: [ownerId], references: [id])
  lead    EmkLead?    @relation("LeadTasks", fields: [relatedLeadId], references: [id])
  account EmkAccount? @relation("AccountTasks", fields: [relatedAccountId], references: [id])

  @@index([ownerId, dueDate])
  @@index([status, dueDate])
  @@index([relatedLeadId])
}

model EmkNote {
  id        String   @id @default(cuid())
  leadId    String?
  accountId String?
  authorId  String
  content   String
  createdAt DateTime @default(now())

  lead    EmkLead?    @relation("LeadNotes", fields: [leadId], references: [id])
  account EmkAccount? @relation("AccountNotes", fields: [accountId], references: [id])
  author  User        @relation("NoteAuthor", fields: [authorId], references: [id])

  @@index([leadId, createdAt])
  @@index([accountId, createdAt])
}

// ─── Affiliate / Agency ───────────────────────────────────

model AffiliateAccount {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE | SUSPENDED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links       AffiliateLink[]
  referrals   Referral[]
  commissions Commission[]
}

model AffiliateLink {
  id          String   @id @default(cuid())
  affiliateId String
  refCode     String   @unique
  targetUrl   String?  // landing slug
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  affiliate AffiliateAccount @relation(fields: [affiliateId], references: [id])

  @@index([refCode])
  @@index([affiliateId])
}

model Referral {
  id          String   @id @default(cuid())
  affiliateId String
  leadId      String   @unique
  refCode     String
  clickedAt   DateTime
  convertedAt DateTime?
  status      String   @default("CLICKED") // CLICKED|LEAD|TRIAL|PAID
  createdAt   DateTime @default(now())

  affiliate AffiliateAccount @relation(fields: [affiliateId], references: [id])
  lead      EmkLead          @relation(fields: [leadId], references: [id])

  @@index([affiliateId, status, createdAt])
}

model Commission {
  id          String    @id @default(cuid())
  affiliateId String
  referralId  String?
  orderId     String?   // commerce order that triggered this
  productId   String?   // product that was purchased
  amount      Int       // VND
  rate        Int?      // commission rate in basis points (e.g. 1000 = 10%)
  status      String    @default("PENDING") // PENDING|HELD|APPROVED|PAID|REJECTED|REVERSED
  holdUntil   DateTime? // hold period before approval
  approvedAt  DateTime?
  paidAt      DateTime?
  reversedAt  DateTime?
  reverseReason String?
  payoutItemId String?
  createdAt   DateTime  @default(now())

  affiliate AffiliateAccount @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId, status, createdAt])
  @@index([orderId])
  @@index([holdUntil, status])
}

model PayoutBatch {
  id        String   @id @default(cuid())
  month     String   // "2026-02"
  total     Int      @default(0) // VND
  status    String   @default("DRAFT") // DRAFT|APPROVED|PAID
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PayoutItem[]
}

model PayoutItem {
  id          String   @id @default(cuid())
  batchId     String
  affiliateId String
  amount      Int
  status      String   @default("PENDING") // PENDING|PAID
  proofUrl    String?
  createdAt   DateTime @default(now())

  batch PayoutBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([affiliateId])
}

// ─── Wallet System ────────────────────────────────────────

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  balanceAvailable Int      @default(0) // VND – tiền thật
  creditBalance    Int      @default(0) // VND – tiền khuyến mãi (không rút được)
  status           String   @default("ACTIVE") // ACTIVE | LOCKED | FROZEN
  currency         String   @default("VND")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id])
  ledger WalletLedger[]

  @@index([status])
}

model WalletLedger {
  id              String   @id @default(cuid())
  walletId        String
  userId          String
  type            String   // TOPUP | SPEND | REFUND | ADJUST
  amount          Int      // >= 0
  direction       String   // CREDIT | DEBIT
  refType         String   // TOPUP_INTENT | TOPUP_CONFIRMED | PURCHASE | SUBSCRIPTION | MINIAPP_USAGE | MANUAL_ADJUST
  refId           String   // id giao dịch liên quan
  idempotencyKey  String   // unique per user, chống lặp
  note            String?
  metadata        Json?
  createdAt       DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([refType, refId])
}

model TopupIntent {
  id              String    @id @default(cuid())
  userId          String
  amount          Int       // >= 100000 VND
  status          String    @default("PENDING") // PENDING | CONFIRMED | EXPIRED | CANCELED
  payMethod       String    @default("BANK_QR")
  bankAccountId   String?
  transferContent String    @unique // EMK{userShort}-{idShort} – nội dung CK duy nhất
  qrPayload       String?  // VietQR deeplink / data
  qrImageUrl      String?
  expiresAt       DateTime?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, status, createdAt])
  @@index([transferContent])
}

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  bankCode      String?  // VietQR bank code
  bin           String?  // VietQR BIN
  accountNumber String
  accountName   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Purchase {
  id          String    @id @default(cuid())
  userId      String
  itemType    String    // PLAN | MINIAPP | FEATURE
  itemId      String
  amount      Int       // VND
  status      String    @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  createdAt   DateTime  @default(now())
  paidAt      DateTime?

  @@index([userId, createdAt])
}

model CmsPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  body        String   @db.Text
  category    String   @default("Tin tức")    // Tin tức, Hướng dẫn, Cập nhật, Khuyến mãi
  status      String   @default("DRAFT")      // DRAFT, PUBLISHED
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
}

// ─── Support Tickets ──────────────────────────────────────
model SupportTicket {
  id          String    @id @default(cuid())
  workspaceId String?
  userId      String
  subject     String
  category    String    @default("GENERAL") // GENERAL|BILLING|TECHNICAL|ACCOUNT
  priority    String    @default("NORMAL")  // LOW|NORMAL|HIGH|URGENT
  status      String    @default("OPEN")    // OPEN|IN_PROGRESS|RESOLVED|CLOSED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String   @db.Text
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
  author User          @relation(fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
}

model EmkEmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   @db.Text
  category  String   @default("GENERAL") // WELCOME|FOLLOW_UP|RENEWAL|PROMO|GENERAL
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User? @relation("TemplateAuthor", fields: [createdBy], references: [id])

  @@index([category, isActive])
}

// ─── Drip Campaigns ──────────────────────────────────────

model EmkDripCampaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  triggerStatus String  @default("NEW")   // Pipeline status that triggers this campaign
  stepsJson   Json     // Array of steps: [{delay: 0, subject, body, channel}]
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User?          @relation("CampaignAuthor", fields: [createdBy], references: [id])
  logs   EmkDripLog[]

  @@index([triggerStatus, isActive])
}

model EmkDripLog {
  id         String   @id @default(cuid())
  campaignId String
  leadId     String
  stepIndex  Int
  channel    String   @default("EMAIL")  // EMAIL | ZALO | SMS
  status     String   @default("SENT")   // SENT | FAILED | SKIPPED
  subject    String?
  sentAt     DateTime @default(now())

  campaign EmkDripCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId, leadId])
  @@index([leadId, sentAt])
}

// ─── Gamification ─────────────────────────────────────────

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  type      String   // BADGE | STREAK | MILESTONE
  key       String   // first_lead, fast_responder, streak_7, leads_100
  label     String   // Display name
  icon      String   @default("🏆")
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, key])
  @@index([userId, earnedAt])
}

// ─── Knowledge Base ───────────────────────────────────────

model KbCategory {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  icon     String  @default("📁")
  sortOrder Int    @default(0)

  articles KbArticle[]
}

model KbArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  categoryId  String
  authorId    String?
  isPublished Boolean  @default(true)
  viewCount   Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category KbCategory @relation(fields: [categoryId], references: [id])
  author   User?      @relation("KbAuthor", fields: [authorId], references: [id])

  @@index([categoryId, isPublished])
  @@index([slug])
}
