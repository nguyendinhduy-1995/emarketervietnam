generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/spa"
}

datasource db {
  provider = "postgresql"
  url      = env("SPA_DATABASE_URL")
}

// ─── Spa CRM Business Tables ──────────────────────────────
// All tables MUST have workspaceId + index on (workspaceId, createdAt)

model Customer {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  phone       String?
  email       String?
  tagsJson    Json?    // ["VIP", "new"]
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
  receipts     Receipt[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, phone])
}

model Service {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  durationMin Int      @default(60)
  price       Int      @default(0) // VND
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
  receiptItems ReceiptItem[]
  commissionRules CommissionRule[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, isActive])
}

model Appointment {
  id          String    @id @default(cuid())
  workspaceId String
  customerId  String
  serviceId   String
  startAt     DateTime
  endAt       DateTime
  status      String    @default("SCHEDULED") // SCHEDULED | CONFIRMED | IN_PROGRESS | COMPLETED | CANCELLED | NO_SHOW
  reminderSent Boolean  @default(false)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, startAt])
  @@index([customerId])
  @@index([serviceId])
}

model Receipt {
  id          String   @id @default(cuid())
  workspaceId String
  customerId  String
  total       Int      @default(0)
  paid        Int      @default(0)
  remaining   Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer      @relation(fields: [customerId], references: [id])
  items    ReceiptItem[]
  commissionTransactions CommissionTransaction[]

  @@index([workspaceId, createdAt])
  @@index([customerId])
}

model ReceiptItem {
  id        String @id @default(cuid())
  receiptId String
  serviceId String
  qty       Int    @default(1)
  price     Int    @default(0)

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([receiptId])
}

model ProductCategory {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([workspaceId, createdAt])
}

model Product {
  id            String    @id @default(cuid())
  workspaceId   String
  categoryId    String?
  name          String
  sku           String?
  price         Int       @default(0) // Selling price
  costPrice     Int       @default(0) // Purchase cost
  stockQuantity Int       @default(0)
  reorderLevel  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category     ProductCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions StockTransaction[]

  @@index([workspaceId, createdAt])
  @@index([categoryId])
}

model StockTransaction {
  id          String   @id @default(cuid())
  workspaceId String
  productId   String
  type        String   // IN | OUT | ADJUSTMENT
  quantity    Int      // Positive for IN, Negative for OUT
  notes       String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([productId])
}

// ─── Payroll & Commissions ────────────────────────────────
model Staff {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  phone       String?
  role        String   @default("STAFF") // STAFF | MANAGER
  baseSalary  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  commissionRules CommissionRule[]
  transactions    CommissionTransaction[]
  payslips        Payslip[]

  @@index([workspaceId, createdAt])
}

model CommissionRule {
  id          String   @id @default(cuid())
  workspaceId String
  staffId     String?  // If null, applies to all staff
  serviceId   String?  // If null, applies to all services
  type        String   @default("PERCENTAGE") // PERCENTAGE | FIXED
  value       Int      @default(0) // e.g. 10 (%) or 50000 (VND)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff   Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, serviceId])
  @@index([workspaceId, staffId])
}

model CommissionTransaction {
  id          String   @id @default(cuid())
  workspaceId String
  staffId     String
  receiptId   String?  // Link to the receipt that generated this commission
  amount      Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  receipt Receipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([staffId])
}

model Payslip {
  id              String   @id @default(cuid())
  workspaceId     String
  staffId         String
  month           Int
  year            Int
  baseSalary      Int      @default(0)
  totalCommission Int      @default(0)
  totalAllowance  Int      @default(0)
  totalDeduction  Int      @default(0)
  netPay          Int      @default(0)
  status          String   @default("DRAFT") // DRAFT | PAID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, staffId, month, year])
  @@index([workspaceId, status])
}

